---
// src/components/Ministerios.astro
const ministerios = [
  {
    nombre: "Pastoral",
    descripcion: "Cuidado, discipulado y guía espiritual basada en la sana doctrina para el crecimiento de la iglesia.",
    icono:
      "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253",
    color: "from-amber-500/20 to-transparent",
    link: "/ministerios/pastoral",
  },
  {
    nombre: "Juvenil",
    descripcion: "Formando jóvenes con identidad bíblica, equipándolos para ser luz en su generación y entorno social.",
    icono:
      "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z",
    color: "from-blue-500/10 to-transparent",
    link: "/ministerios/juvenil",
  },
  {
    nombre: "Ayuda Social",
    descripcion: "La fe expresada en amor práctico. Atendemos necesidades tangibles en nuestra comunidad de Coro.",
    icono:
      "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z",
    color: "from-red-500/10 to-transparent",
    link: "/ayuda-social",
  },
  {
    nombre: "Adoración",
    descripcion: "Guiando a la congregación al trono de la gracia a través de la alabanza y la excelencia musical.",
    icono:
      "M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3",
    color: "from-purple-500/10 to-transparent",
    link: "/ministerios/adoracion-y-alabanzas",
  },
  {
    nombre: "Intercesión",
    descripcion: "Sosteniendo la obra de Dios en oración constante, clamando por las familias y nuestra nación.",
    icono: "M4.5 12.75l6 6 9-13.5",
    iconoSVG:
      "M12 21l-8.228-3.654A2 2 0 012.62 15.513V4.24a2 2 0 012.31-1.974l8.07 1.344 8.07-1.344a2 2 0 012.31 1.974v11.273a2 2 0 01-1.152 1.833L12 21z",
    color: "from-teal-500/10 to-transparent",
    link: "/intercesion",
  },
];
---

<section id="ministerios" class="py-24 bg-[#101829] relative overflow-hidden">
  <div
    class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/2 w-[500px] h-[500px] bg-[#D4AF37]/5 rounded-full blur-[120px]"
  >
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-20">
      <h2 class="text-[#D4AF37] font-bold tracking-widest text-sm uppercase mb-3">Nuestra Familia en Acción</h2>
      <p class="text-4xl md:text-5xl font-bold text-white mb-6 leading-tight text-balance">
        Un Lugar para <span class="text-[#D4AF37]">Servir</span> y Crecer
      </p>
      <p class="text-slate-400 text-lg font-light">
        Entendemos que cada miembro es un obrero útil en las manos del Maestro. Descubre dónde puedes poner tus dones al
        servicio del Reino.
      </p>
    </div>

    <div id="contenedor-ministerios" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        ministerios.map((m, index) => (
          <div
            class="card-ministerio group relative p-8 rounded-3xl border border-white/5 bg-gradient-to-br transition-all duration-700 opacity-0 translate-y-20 hover:border-[#D4AF37]/40 hover:-translate-y-2"
            style={`transition-delay: ${index * 100}ms;`}
            class:list={[m.color]}
          >
            <div class="mb-6 inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-[#0c121e] border border-white/10 group-hover:border-[#D4AF37]/50 transition-colors">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="w-7 h-7 text-[#D4AF37]"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d={m.iconoSVG || m.icono} />
              </svg>
            </div>

            <h3 class="text-2xl font-bold text-white mb-4 italic">{m.nombre}</h3>
            <p class="text-slate-400 leading-relaxed font-light mb-6">{m.descripcion}</p>

            <a
              href={m.link}
              class="inline-flex items-center text-sm font-semibold text-[#D4AF37] hover:gap-2 transition-all"
            >
              Saber más
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
                class="w-4 h-4 ml-1"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>
        ))
      }

      <div
        class="card-ministerio p-8 rounded-3xl border border-dashed border-white/20 flex flex-col items-center justify-center text-center group hover:bg-white/5 transition-all duration-700 opacity-0 translate-y-20"
        style={`transition-delay: ${ministerios.length * 100}ms;`}
      >
        <div
          class="w-12 h-12 rounded-full border border-dashed border-white/30 flex items-center justify-center text-white/30 mb-4 group-hover:scale-110 transition-transform"
        >
          <span class="text-2xl">+</span>
        </div>
        <p class="text-slate-300 font-medium italic">¿Tienes un don especial?</p>
        <p class="text-slate-500 text-xs mt-2">Estamos listos para apoyarte en tu llamado.</p>
      </div>
    </div>
  </div>
</section>

<script>
  const animarMinisterios = () => {
    const contenedor = document.getElementById("contenedor-ministerios");
    const cards = document.querySelectorAll(".card-ministerio");

    if (!contenedor || cards.length === 0) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            cards.forEach((card) => {
              card.classList.remove("opacity-0", "translate-y-20");
              card.classList.add("opacity-100", "translate-y-0");
            });
            observer.unobserve(contenedor);
          }
        });
      },
      {
        rootMargin: "0px 0px -50px 0px",
        threshold: 0.1,
      },
    );

    observer.observe(contenedor);
  };

  // Ejecutar al cargar y tras cambios de página (Astro View Transitions)
  animarMinisterios();
  document.addEventListener("astro:after-swap", animarMinisterios);
</script>
