---
// src/components/Fundamentos.astro (Actualizado)
const fundamentos = [
  {
    titulo: "Estudio Diligente",
    descripcion:
      "No tomamos la Palabra a la ligera. Escudriñamos las Escrituras con rigor exegético para entender el consejo de Dios.",
    img: "https://images.unsplash.com/photo-1507434965515-61970f2bd7c6?q=80&w=800&auto=format&fit=crop",
    alt: "Estudio Bíblico",
  },
  {
    titulo: "Vida Aprobada",
    descripcion:
      "Buscamos que nuestra conducta en Coro sea un testimonio vivo, viviendo como obreros que no tienen de qué avergonzarse.",
    img: "https://images.unsplash.com/photo-1490730141103-6cac27aaab94?q=80&w=800&auto=format&fit=crop",
    alt: "Integridad Cristiana",
  },
  {
    titulo: "Verdad Inmutable",
    descripcion:
      "Predicamos a Cristo crucificado, sin añadir ni quitar, usando bien la palabra de verdad en cada sermón.",
    img: "https://images.unsplash.com/photo-1515162305285-0293e4767cc2?q=80&w=800&auto=format&fit=crop",
    alt: "Predicación Fiel",
  },
];
---

<section id="fundamentos" class="py-24 bg-[#0c121e] relative">
  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-3xl mb-16">
      <h2 class="text-[#D4AF37] font-bold tracking-widest text-sm uppercase mb-3 text-balance">
        Basados en 2 Timoteo 2:15
      </h2>
      <p class="text-3xl md:text-5xl font-bold text-white mb-6">
        Comprometidos con la <span class="italic font-light text-[#D4AF37]">Exposición Fiel</span>
      </p>
      <div class="h-1 w-20 bg-[#D4AF37] mb-8"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {
        fundamentos.map((item) => (
          <div class="group bg-[#101829] border border-white/5 rounded-2xl overflow-hidden hover:border-[#D4AF37]/50 transition-all duration-500">
            <div class="h-56 overflow-hidden relative">
              <img
                src={item.img}
                alt={item.alt}
                class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700"
              />
            </div>
            <div class="p-8">
              <h3 class="text-xl font-bold text-white mb-4 italic italic">{item.titulo}</h3>
              <p class="text-slate-400 text-sm leading-relaxed leading-relaxed font-light">{item.descripcion}</p>
            </div>
          </div>
        ))
      }
    </div>

    <div class="mt-20 text-center border-t border-white/5 pt-10">
      <blockquote class="text-slate-400 italic text-2xl font-serif max-w-2xl mx-auto">
        "Procura con diligencia presentarte a Dios aprobado, como obrero que no tiene de qué avergonzarse..."
      </blockquote>
      <p class="text-[#D4AF37] mt-4 font-bold tracking-widest uppercase text-sm">— 2 Timoteo 2:15</p>
    </div>
  </div>
</section>
