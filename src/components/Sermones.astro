---
// Importamos el video desde la carpeta de assets
// import videoFondo from "../assets/videos/fondovideo1.mp4";
import videoFondo2 from "../assets/videos/fondovideo2.mp4";
---

<section class="relative h-[70vh] min-h-[500px] flex items-center justify-center overflow-hidden">
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-[#101829]/70 z-10"></div>

    <div class="absolute inset-0 bg-gradient-to-b from-[#0c121e] via-transparent to-[#101829] z-20"></div>

    <video autoplay muted loop playsinline class="w-full h-full object-cover">
      <source src={videoFondo2} type="video/mp4" />
      Tu navegador no soporta video.
    </video>
  </div>

  <div class="container mx-auto px-6 relative z-30 text-center">
    <div class="max-w-3xl mx-auto">
      <div class="inline-block mb-6">
        <div class="h-[1px] w-12 bg-[#D4AF37] mx-auto mb-4"></div>
        <span class="text-[#D4AF37] font-bold tracking-[0.4em] text-xs uppercase"> Biblioteca de Enseñanzas </span>
      </div>

      <h2 class="text-4xl md:text-6xl font-bold text-white mb-6 leading-tight">
        Sermones que <span class="text-[#D4AF37] italic font-serif">Transforman</span>
      </h2>

      <p class="text-lg md:text-xl text-slate-300 mb-10 font-light leading-relaxed">
        Explora nuestra exposición fiel de las Escrituras. Cada mensaje está diseñado para equipar al obrero y alimentar
        el alma con sana doctrina.
      </p>

      <div class="flex flex-col sm:flex-row gap-5 justify-center">
        <a
          href="https://www.youtube.com/@TuCanal"
          target="_blank"
          class="group relative px-10 py-4 bg-[#D4AF37] text-[#101829] font-extrabold rounded-full overflow-hidden transition-all hover:scale-105"
        >
          <span class="relative z-10 flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
              ></path>
            </svg>
            IR AL CANAL DE YOUTUBE
          </span>
        </a>

        <a
          href="#estudios"
          class="px-10 py-4 bg-white/5 backdrop-blur-md border border-white/10 text-white font-semibold rounded-full hover:bg-white/10 transition-all"
        >
          Últimas Series
        </a>
      </div>
    </div>
  </div>
</section>
