---
// src/components/Hero.astro
import { Image } from "astro:assets";
import logoImage from "../assets/images/logo-iglesia.png";
---

<section class="relative min-h-screen flex items-center justify-center bg-[#101829] overflow-hidden pt-16">
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full bg-[radial-gradient(circle_at_center,rgba(212,175,55,0.05)_0%,transparent_70%)]"
  >
  </div>

  <div class="container mx-auto px-6 relative z-10 text-center flex flex-col items-center">
    <div class="mb-8 relative group">
      <div class="relative bg-[#101829] p-4 rounded-full border border-white/10 shadow-2xl">
        <Image src={logoImage} alt="Logo Iglesia Coro" class="h-24 md:h-32 w-auto object-contain" loading="eager" />
      </div>
    </div>

    <span
      class="inline-block px-4 py-1 mb-6 text-sm font-semibold tracking-[0.2em] text-[#D4AF37] uppercase border border-[#D4AF37]/30 rounded-full bg-[#D4AF37]/5 backdrop-blur-sm"
    >
      Coro, Edo. Falcón • La Urbina
    </span>

    <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-[1.1] max-w-4xl">
      Arraigados en la <span class="text-[#D4AF37]">Palabra</span>, <br />
      Edificados en la Verdad.
    </h1>

    <p class="max-w-2xl mx-auto text-lg md:text-xl text-slate-400 mb-10 leading-relaxed font-light">
      Una comunidad cristiana en Coro comprometida con la <span class="text-slate-200 font-medium">sana doctrina</span> y
      las Sagradas Escrituras como nuestra única regla de fe y conducta.
    </p>

    <div class="flex flex-col sm:flex-row gap-5 justify-center w-full sm:w-auto">
      <a
        href="#horarios"
        class="px-10 py-4 bg-[#D4AF37] hover:bg-[#b8962d] text-[#101829] font-extrabold rounded-lg transition-all transform hover:scale-105 shadow-xl shadow-[#D4AF37]/10 uppercase tracking-wider text-sm"
      >
        Visítanos este Domingo
      </a>
      <a
        href="#nosotros"
        class="px-10 py-4 bg-transparent border border-slate-700 hover:border-slate-500 text-white font-semibold rounded-lg transition-all backdrop-blur-sm uppercase tracking-wider text-sm"
      >
        Nuestros Fundamentos
      </a>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-[0]">
    <svg
      class="relative block w-full h-[80px]"
      data-name="Layer 1"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 1200 120"
      preserveAspectRatio="none"
    >
      <path d="M1200 120L0 120L0 0L1200 120Z" fill="#0c121e"></path>
    </svg>
  </div>
</section>
