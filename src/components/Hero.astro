---
// src/components/Hero.astro (Actualizado con 2 Timoteo 2:15)
import { Image } from "astro:assets";
import logoImage from "../assets/images/logo-iglesia.png";
---

<section class="relative min-h-screen flex items-center justify-center bg-[#101829] overflow-hidden pt-16">
  <div class="container mx-auto px-6 relative z-10 text-center flex flex-col items-center">
    <div class="mb-8 relative group">
      <div class="absolute -inset-1 rounded-full blur-xl group-hover:bg-[#D4AF37]/30 transition duration-1000"></div>
      <div class="relative bg-[#101829] p-4 rounded-full border border-white/10 shadow-2xl">
        <Image src={logoImage} alt="Logo" class="h-24 md:h-32 w-auto object-contain" loading="eager" />
      </div>
    </div>

    <span
      class="inline-block px-4 py-1 mb-6 text-sm font-semibold tracking-[0.2em] text-[#D4AF37] uppercase border border-[#D4AF37]/30 rounded-full bg-[#D4AF37]/5"
    >
      Coro, Edo. Falcón • La Urbina
    </span>

    <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-[1.1] max-w-5xl text-balance">
      Obreros que <span class="text-[#D4AF37]">usan bien</span>
      <br />
      la Palabra de Verdad.
    </h1>

    <p class="max-w-3xl mx-auto text-lg md:text-xl text-slate-400 mb-10 leading-relaxed font-light">
      En La Urbina, procuramos con diligencia presentarnos ante Dios aprobados, <span class="text-slate-200"
        >estudiando con fidelidad</span
      > las Escrituras para vivir conforme a Su voluntad.
    </p>

    <div class="flex flex-col sm:flex-row gap-5 justify-center">
      <a
        href="#horarios"
        class="px-10 py-4 bg-[#D4AF37] hover:bg-[#b8962d] text-[#101829] font-extrabold rounded-lg transition-all transform hover:scale-105 uppercase tracking-wider text-sm"
      >
        Únete a nuestro estudio
      </a>
      <a
        href="#fundamentos"
        class="px-10 py-4 bg-transparent border border-slate-700 text-white font-semibold rounded-lg transition-all uppercase tracking-wider text-sm"
      >
        Nuestra Doctrina
      </a>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-[0]">
    <svg class="relative block w-full h-[80px]" viewBox="0 0 1200 120" preserveAspectRatio="none">
      <path d="M1200 120L0 120L0 0L1200 120Z" fill="#0c121e"></path>
    </svg>
  </div>
</section>
